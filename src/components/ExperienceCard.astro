---
const { frontmatter, url } = Astro.props;
---

<a href={url} class="experience-card">
  <div class="timeline-marker">
    <div class="timeline-dot"></div>
  </div>
  
  <div class="card-content">
    <div class="card-header">
      <h3 class="title">{frontmatter.title}</h3>
      <span class="period">{frontmatter.periodo}</span>
    </div>
    
    <div class="card-meta">
      <span class="role">{frontmatter.cargo}</span>
      <span class="separator">•</span>
      <span class="company">{frontmatter.empresa}</span>
    </div>
    
    {frontmatter.tecnologias && frontmatter.tecnologias.length > 0 && (
      <div class="tech-preview">
        {frontmatter.tecnologias.slice(0, 4).map((tech: string) => (
          <span class="tech-tag">{tech}</span>
        ))}
        {frontmatter.tecnologias.length > 4 && (
          <span class="tech-more">+{frontmatter.tecnologias.length - 4}</span>
        )}
      </div>
    )}
    
    {frontmatter.descricao && (
      <p class="description">{frontmatter.descricao}</p>
    )}
  </div>
</a>

<style>
.experience-card {
  display: grid;
  grid-template-columns: 40px 1fr;
  gap: 1.5rem;
  padding: 1.5rem 0;
  text-decoration: none;
  color: inherit;
  position: relative;
  transition: all 0.2s ease;
}

.experience-card:not(:last-child) {
  border-bottom: 1px solid color-mix(in srgb, var(--text-color) 8%, transparent);
}

.experience-card:hover .card-content {
  transform: translateX(4px);
}

.experience-card:hover .timeline-dot {
  background: var(--accent-color);
  transform: scale(1.3);
  box-shadow: 0 0 0 4px color-mix(in srgb, var(--accent-color) 15%, transparent);
}

.timeline-marker {
  position: relative;
  display: flex;
  justify-content: center;
  padding-top: 0.3rem;
}

.timeline-marker::before {
  content: '';
  position: absolute;
  top: 0;
  bottom: -100%;
  width: 2px;
  background: color-mix(in srgb, var(--text-color) 10%, transparent);
  left: 50%;
  transform: translateX(-50%);
}

.experience-card:last-child .timeline-marker::before {
  display: none;
}

.timeline-dot {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  background: color-mix(in srgb, var(--text-color) 30%, transparent);
  border: 2px solid var(--background-color);
  z-index: 1;
  transition: all 0.3s ease;
}

.card-content {
  transition: transform 0.2s ease;
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  margin-bottom: 0.5rem;
  flex-wrap: wrap;
}

.title {
  margin: 0;
  font-size: 1.4rem;
  font-weight: 600;
  color: var(--text-color);
}

.period {
  font-size: 0.95rem;
  font-weight: 600;
  color: var(--accent-color);
  white-space: nowrap;
}

.card-meta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  font-size: 1rem;
  margin-bottom: 0.8rem;
  opacity: 0.8;
}

.role {
  font-style: italic;
  font-weight: 500;
}

.separator {
  opacity: 0.5;
}

.company {
  opacity: 0.85;
}

.tech-preview {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
  margin: 0.8rem 0;
}

.tech-tag {
  padding: 0.25rem 0.6rem;
  font-size: 0.75rem;
  background: color-mix(in srgb, var(--text-color) 5%, transparent);
  border: 1px solid color-mix(in srgb, var(--text-color) 10%, transparent);
  border-radius: 3px;
  font-weight: 500;
}

.tech-more {
  padding: 0.25rem 0.6rem;
  font-size: 0.75rem;
  color: var(--accent-color);
  font-weight: 600;
}

.description {
  margin: 0.8rem 0 0 0;
  font-size: 0.95rem;
  line-height: 1.6;
  opacity: 0.85;
  text-align: left;
}

@media (max-width: 768px) {
  .experience-card {
    grid-template-columns: 30px 1fr;
    gap: 1rem;
    padding: 1.2rem 0;
  }
  
  .card-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.3rem;
  }
  
  .title {
    font-size: 1.2rem;
  }
  
  .period {
    font-size: 0.85rem;
  }
  
  .card-meta {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
  }
  
  .separator {
    display: none;
  }
  
  .tech-preview {
    gap: 0.3rem;
  }
  
  .tech-tag, .tech-more {
    font-size: 0.7rem;
  }
}
</style>
