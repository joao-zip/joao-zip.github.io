---
const { frontmatter } = Astro.props;
const isEn = Astro.url.pathname.startsWith('/en');

const formatCategory = (cat: string) => {
  const ptMap: Record<string, string> = {
    univ: 'Acadêmico',
    personal: 'Pessoal',
    opensource: 'Open-Source'
  };
  const enMap: Record<string, string> = {
    univ: 'Academic',
    personal: 'Personal',
    opensource: 'Open-Source'
  };
  const map = isEn ? enMap : ptMap;
  return (map[cat] || cat).toUpperCase();
};
---

<div class="project-card">
  <div class="card-main-content">
    <div class="card-top">
      {frontmatter.categories && frontmatter.categories.length > 0 && (
        <span class="card-category">
          {frontmatter.categories.map((c: string) => formatCategory(c)).join(' · ')}
        </span>
      )}
      {frontmatter.period && (
        <span class="period">{frontmatter.period}</span>
      )}
    </div>

    <h3 class="card-title">{frontmatter.title}</h3>

    <div class="card-divider"></div>

    {frontmatter.description && (
      <p class="description">{frontmatter.description}</p>
    )}
  </div>

  {frontmatter.img && (
    <div class="card-image-wrapper">
      <img src={frontmatter.img} alt={frontmatter.title} class="card-image" />
    </div>
  )}
</div>

<style>
.project-card {
  padding: 1.2rem;
  display: flex;
  gap: 1.2rem;
  align-items: center;
  background: transparent;
  border: 1px solid color-mix(in srgb, var(--text-color) 12%, transparent);
  border-radius: 0; /* Flat corners for editorial newspaper clipping style */
  transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
  min-height: 95px;
}

.project-card:hover {
  border-color: color-mix(in srgb, var(--text-color) 35%, transparent);
  background: color-mix(in srgb, var(--text-color) 3%, transparent);
  transform: translateY(-2px);
}

.card-main-content {
  flex: 1;
  display: flex;
  flex-direction: column;
  min-width: 0; /* Prevents flex children from breaking parent layout */
}

.card-top {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 0.5rem;
  margin-bottom: 0.4rem;
  flex-wrap: wrap;
}

.card-category {
  font-family: Courier, "Courier New", Monaco, monospace;
  font-size: 0.75rem;
  font-weight: 700;
  color: var(--accent-color);
  letter-spacing: 0.5px;
}

.period {
  font-family: Courier, "Courier New", Monaco, monospace;
  font-size: 0.75rem;
  font-weight: 600;
  color: var(--text-color);
  opacity: 0.7;
  white-space: nowrap;
}

.card-title {
  margin: 0.1rem 0;
  font-family: "Crimson Text", Georgia, serif;
  font-size: 1.2rem;
  font-weight: 700;
  line-height: 1.25;
  color: var(--text-color);
}

.card-divider {
  border-top: 3px double color-mix(in srgb, var(--text-color) 25%, transparent);
  height: 0;
  margin: 0.5rem 0;
}

.description {
  margin: 0;
  font-family: "Crimson Text", Georgia, serif;
  font-size: 0.95rem;
  line-height: 1.45;
  color: var(--text-color);
  opacity: 0.85;
  text-align: justify;
  text-justify: inter-word;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* Wrapper for project logo */
.card-image-wrapper {
  flex-shrink: 0;
  width: 65px;
  height: 65px;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-image {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
  filter: grayscale(20%); /* Soft vintage print filter */
  opacity: 0.9;
}

@media (max-width: 768px) {
  .project-card {
    padding: 1rem;
    min-height: 85px;
    gap: 1rem;
  }
  
  .card-top {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.2rem;
  }
  
  .card-title {
    font-size: 1.1rem;
  }
  
  .description {
    font-size: 0.9rem;
  }

  .card-image-wrapper {
    width: 55px;
    height: 55px;
  }
}
</style>
