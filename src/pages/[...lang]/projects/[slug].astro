---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../../layouts/Base.astro';
import { locales, defaultLang, type Lang } from '../../../i18n/utils';
import { getSkillIconId } from '../../../utils/techIcons';

export async function getStaticPaths() {
  const paths = [];
  for (const lang of locales) {
    const projects = await getCollection('projects', ({ id }) => id.startsWith(`${lang}/`));
    for (const project of projects) {
      paths.push({
        params: {
          lang: lang === defaultLang ? undefined : lang,
          slug: project.slug.replace(`${lang}/`, ''),
        },
        props: { project, lang },
      });
    }
  }
  return paths;
}

const { project, lang } = Astro.props;
const { Content } = await project.render();
const { title, period, img, technologies, site, github } = project.data;
---

<Base titlePage={title} lang={lang}>

  <div class="project-header">
    <h1>{title}</h1>
    {period && (
      <div class="project-meta">
        <span class="meta-period">{period}</span>
      </div>
    )}
  </div>

  {technologies && technologies.length > 0 && (
    <div class="project-tech-section">
      {technologies.map((tech: string) => {
        const iconId = getSkillIconId(tech);
        return (
          <span class="tech-chip">
            {iconId && (
              <img 
                src={`https://skillicons.dev/icons?i=${iconId}`} 
                alt="" 
                class="tech-icon" 
                width="16" 
                height="16" 
                loading="lazy" 
              />
            )}
            <span>{tech}</span>
          </span>
        );
      })}
    </div>
  )}

  {img && (
    <Image
      src={img} 
      alt="Project logo" 
      loading="lazy"
      height={220} 
      width={220}
      class="project-image"
    />
  )}

  <Content />

  <div class="project-links">
    {site && <a href={site} target="_blank">Site</a>}
    {github && <a href={github} target="_blank">Repo</a>}
  </div>

</Base>

<style>
.project-header {
  margin-bottom: 1.5rem;
}

.project-header h1 {
  margin-bottom: 0.5rem;
}

.project-meta {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
}

.meta-period {
  font-size: 0.95rem;
  color: var(--accent-color);
  font-weight: 500;
  padding: 0.3rem 0.8rem;
  background: color-mix(in srgb, var(--accent-color) 8%, transparent);
  border: 1px solid color-mix(in srgb, var(--accent-color) 20%, transparent);
  border-radius: 6px;
}

.project-image {
  float: right;
  margin: 15px;
}

.project-links {
  display: flex;
  gap: 1rem;
  justify-content: center;
  margin-top: 2rem;
  clear: both;
}

.project-links a {
  padding: 0.6rem 1.5rem;
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-color);
  opacity: 0.8;
  text-decoration: none;
  background: transparent;
  border: 1px solid color-mix(in srgb, var(--text-color) 15%, transparent);
  border-radius: 6px;
  transition: all 0.2s ease;
  letter-spacing: 0.02em;
}

.project-links a:hover {
  opacity: 1;
  background: color-mix(in srgb, var(--text-color) 5%, transparent);
  border-color: color-mix(in srgb, var(--text-color) 25%, transparent);
  transform: translateY(-1px);
}

.project-tech-section {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin: 1.5rem 0 2rem 0;
}

.tech-chip {
  display: flex;
  align-items: center;
  gap: 0.4rem;
  padding: 0.35rem 0.75rem;
  font-family: Courier, "Courier New", Monaco, monospace;
  font-size: 0.85rem;
  font-weight: 500;
  background: color-mix(in srgb, var(--text-color) 4%, transparent);
  border: 1px solid color-mix(in srgb, var(--text-color) 10%, transparent);
  border-radius: 4px;
  color: var(--text-color);
  opacity: 0.95;
}

.tech-icon {
  width: 16px;
  height: 16px;
  object-fit: contain;
}

@media (max-width: 768px) {
  .project-tech-section {
    justify-content: center;
    gap: 0.4rem;
    margin: 1rem 0 1.5rem 0;
  }
  
  .tech-chip {
    font-size: 0.8rem;
    padding: 0.25rem 0.6rem;
    gap: 0.3rem;
  }
  
  .tech-icon {
    width: 14px;
    height: 14px;
  }

  .project-header {
    text-align: center;
  }

  .project-meta {
    font-size: 0.9rem;
    justify-content: center;
  }
  
  .meta-period {
    font-size: 0.85rem;
    padding: 0.25rem 0.6rem;
  }

  .project-image {
    float: none;
    display: block;
    margin: 0 auto 1.5rem auto;
  }
}
</style>
