---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import ExperienceCard from '../../../components/ExperienceCard.astro';
import { useTranslations, getLocalizedPath, getCvPath, locales, defaultLang, type Lang } from '../../../i18n/utils';

export async function getStaticPaths() {
  const paths = [];
  for (const lang of locales) {
    const allExperiences = await getCollection('experience', ({ id }) => id.startsWith(`${lang}/`));

    allExperiences.sort((a, b) => {
      const aIsCurrent = a.data.period.includes('Atual') || a.data.period.includes('Current');
      const bIsCurrent = b.data.period.includes('Atual') || b.data.period.includes('Current');
      
      if (aIsCurrent && !bIsCurrent) return -1;
      if (!aIsCurrent && bIsCurrent) return 1;
      
      const aYear = parseInt(a.data.period.match(/\d{4}/)?.[0] || '0');
      const bYear = parseInt(b.data.period.match(/\d{4}/)?.[0] || '0');
      return bYear - aYear;
    });

    paths.push({
      params: { lang: lang === defaultLang ? undefined : lang },
      props: { lang, allExperiences },
    });
  }
  return paths;
}

const { lang, allExperiences } = Astro.props;
const t = useTranslations(lang as Lang);
---

<Base titlePage={t('experience.title')} lang={lang}>

  <div class="experience-page">
    <header class="page-header">
      <h1>{t('experience.title')}</h1>
      <p class="subtitle">{t('experience.subtitle')}</p>
    </header>

    <div class="timeline-container">
      {allExperiences.map((experience: any) => {
        const slug = experience.slug.replace(`${lang}/`, '');
        return (
          <ExperienceCard 
            frontmatter={experience.data} 
            url={getLocalizedPath(`/experience/${slug}`, lang as Lang)}
          />
        );
      })}
    </div>

    <div class="cta-section">
      <p>{t('experience.cta_text')}</p>
      <div class="cta-buttons">
        <a href={getCvPath(lang as Lang)} class="cta-button primary" download>{t('experience.download_cv')}</a>
        <a href={getLocalizedPath('/aboutme', lang as Lang)} class="cta-button secondary">{t('experience.about_me')}</a>
      </div>
    </div>
  </div>

</Base>

<style>
.experience-page {
  max-width: 900px;
  margin: 0 auto;
}

.page-header {
  margin-bottom: 3rem;
  text-align: center;
}

.page-header h1 {
  margin-bottom: 0.5rem;
  font-size: 2.5rem;
  color: var(--accent-color);
}

.subtitle {
  font-size: 1.1rem;
  opacity: 0.8;
  margin: 0;
  font-style: italic;
}

.timeline-container {
  position: relative;
  margin: 2rem 0 4rem 0;
}

.cta-section {
  margin-top: 4rem;
  padding: 2rem;
  text-align: center;
  background: color-mix(in srgb, var(--accent-color) 5%, transparent);
  border: 1px solid color-mix(in srgb, var(--accent-color) 15%, transparent);
  border-radius: 8px;
}

.cta-section p {
  margin: 0 0 1.5rem 0;
  font-size: 1.1rem;
  text-align: center;
}

.cta-buttons {
  display: flex;
  gap: 1rem;
  justify-content: center;
  flex-wrap: wrap;
}

.cta-button {
  padding: 0.7rem 1.8rem;
  font-size: 0.95rem;
  font-weight: 500;
  text-decoration: none;
  border-radius: 6px;
  transition: all 0.2s ease;
  letter-spacing: 0.02em;
  display: inline-block;
}

.cta-button.primary {
  background: var(--accent-color);
  color: var(--background-color);
  border: 2px solid var(--accent-color);
}

.cta-button.primary:hover {
  background: var(--accent-hover);
  border-color: var(--accent-hover);
  transform: translateY(-2px);
  box-shadow: 0 4px 12px color-mix(in srgb, var(--accent-color) 30%, transparent);
}

.cta-button.secondary {
  background: transparent;
  color: var(--text-color);
  border: 2px solid color-mix(in srgb, var(--text-color) 20%, transparent);
}

.cta-button.secondary:hover {
  background: color-mix(in srgb, var(--text-color) 5%, transparent);
  border-color: color-mix(in srgb, var(--text-color) 30%, transparent);
  transform: translateY(-2px);
}

@media (max-width: 768px) {
  .page-header h1 {
    font-size: 2rem;
  }
  
  .subtitle {
    font-size: 1rem;
  }
  
  .timeline-container {
    margin: 1.5rem 0 3rem 0;
  }
  
  .cta-section {
    padding: 1.5rem 1rem;
    margin-top: 3rem;
  }
  
  .cta-section p {
    font-size: 1rem;
  }
  
  .cta-buttons {
    flex-direction: column;
    gap: 0.8rem;
  }
  
  .cta-button {
    width: 100%;
    padding: 0.6rem 1rem;
    font-size: 0.9rem;
    box-sizing: border-box;
    text-align: center;
  }
}

@media (max-width: 480px) {
  .cta-section {
    padding: 1rem 0.8rem;
  }

  .cta-button {
    padding: 0.5rem 0.8rem;
    font-size: 0.85rem;
  }
}
</style>
