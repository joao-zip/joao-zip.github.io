---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { useTranslations, getLocalizedPath, getCvPath, langParams, type Lang } from '../../i18n/utils';
import { getSkillIconId } from '../../utils/techIcons';

export function getStaticPaths() {
  return langParams();
}

const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);

const skillCategories = [
  {
    titleKey: 'about.skills_languages',
    skills: ['C#', 'C++', 'Go', 'TypeScript', 'Python', 'C']
  },
  {
    titleKey: 'about.skills_frameworks',
    skills: ['ASP.NET Core', 'Vue.js', 'Astro.js', 'Qt Framework', 'Entity Framework', 'PyTorch']
  },
  {
    titleKey: 'about.skills_data_messaging',
    skills: ['SQL Server', 'RabbitMQ']
  },
  {
    titleKey: 'about.skills_tools_os',
    skills: ['Git', 'Docker', 'CMake', 'Arch Linux (AUR)']
  }
];
---

<Base titlePage={t('about.title')} lang={lang}>

  <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" media="print" onload="this.media='all'">
  <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async defer></script>
  
  <h1>{t('about.title')}</h1>

  <Image
  src="/me.jpg" alt="João Pedro" 
  loading="eager"
  height={200} width={200}
  class="profile-image"
  />

  <p set:html={t('about.intro')} />

  <h2>{t('about.current_experience_title')}</h2>
  <p set:html={t('about.current_experience_text')} />

  <div class="experience-cta">
    <a href={getLocalizedPath('/experience', lang)} class="cta-link">{t('about.see_full_experience')}</a>
  </div>

  <h2>{t('about.skills_title')}</h2>
  <div class="skills-grid">
    {skillCategories.map(category => (
      <div class="skills-category">
        <h3>{t(category.titleKey as any)}</h3>
        <div class="skills-tags">
          {category.skills.map(tech => {
            const iconId = getSkillIconId(tech);
            return (
              <span class="skill-tag">
                {iconId && (
                  <img 
                    src={`https://skillicons.dev/icons?i=${iconId}`} 
                    alt="" 
                    class="skill-icon" 
                    width="14" 
                    height="14" 
                    loading="lazy" 
                  />
                )}
                <span>{tech}</span>
              </span>
            );
          })}
        </div>
      </div>
    ))}
  </div>

  <h2>{t('about.outside_code_title')}</h2>
  <p>{t('about.outside_code_text')}</p>

  <h2>{t('about.lets_talk_title')}</h2>
  <p>{t('about.lets_talk_text')}</p>
  
  <div style="margin-top: 2rem; text-align: center; display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
    <a class="download-button" href={getCvPath(lang)} download>{t('about.download_cv')}</a>
    <a class="download-button secondary" href="" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/oliveira-joao-unifesp/30min'});return false;">{t('about.schedule_call')}</a>
  </div>

</Base>

<style>
.profile-image {
  float: right;
  border-radius: 10px;
  margin-left: 15px;
}

a {
  text-decoration: underline;
}

p {
  text-align: justify;
}

h2 {
  margin-top: 2rem;
  margin-bottom: 0.5rem;
  font-size: 1.5rem;
  color: var(--accent-color);
}

.experience-cta {
  margin: 1.5rem 0 0.5rem 0;
  text-align: center;
}

.cta-link {
  display: inline-block;
  padding: 0.6rem 1.5rem;
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--accent-color);
  text-decoration: none;
  background: color-mix(in srgb, var(--accent-color) 8%, transparent);
  border: 1px solid color-mix(in srgb, var(--accent-color) 20%, transparent);
  border-radius: 6px;
  transition: all 0.2s ease;
  letter-spacing: 0.02em;
}

.cta-link:hover {
  background: color-mix(in srgb, var(--accent-color) 15%, transparent);
  border-color: var(--accent-color);
  transform: translateY(-1px);
}

/* Skills section styling */
.skills-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 1.5rem;
  margin: 1.5rem 0 2rem 0;
}

.skills-category {
  background: color-mix(in srgb, var(--text-color) 2%, transparent);
  border: 1px dashed color-mix(in srgb, var(--text-color) 15%, transparent);
  padding: 1.2rem;
  border-radius: 0;
}

.skills-category h3 {
  font-family: Courier, "Courier New", Monaco, monospace;
  font-size: 0.9rem;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--accent-color);
  margin: 0 0 0.8rem 0;
  letter-spacing: 0.5px;
  border-bottom: 3px double color-mix(in srgb, var(--text-color) 15%, transparent);
  padding-bottom: 0.5rem;
}

.skills-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.skill-tag {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.2rem 0.5rem;
  font-family: Courier, "Courier New", Monaco, monospace;
  font-size: 0.75rem;
  font-weight: 500;
  background: color-mix(in srgb, var(--text-color) 4%, transparent);
  border: 1px solid color-mix(in srgb, var(--text-color) 8%, transparent);
  color: var(--text-color);
}

.skill-icon {
  width: 14px;
  height: 14px;
  object-fit: contain;
}

.download-button {
  padding: 0.6rem 1.5rem;
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-color);
  opacity: 0.8;
  text-decoration: none;
  background: transparent;
  border: 1px solid color-mix(in srgb, var(--text-color) 15%, transparent);
  border-radius: 6px;
  transition: all 0.2s ease;
  letter-spacing: 0.02em;
  display: inline-block;
}

.download-button:hover {
  opacity: 1;
  background: color-mix(in srgb, var(--text-color) 5%, transparent);
  border-color: color-mix(in srgb, var(--text-color) 25%, transparent);
  transform: translateY(-1px);
}

.download-button.secondary {
  background: var(--accent-color);
  color: var(--background-color);
  border-color: var(--accent-color);
  opacity: 1;
}

.download-button.secondary:hover {
  background: var(--accent-hover);
  border-color: var(--accent-hover);
  color: var(--background-color);
}

@media (max-width: 768px) {
  .skills-grid {
    grid-template-columns: 1fr;
    gap: 1rem;
  }
}

@media (max-width: 768px) {
  .profile-image {
    float: none;
    display: block;
    margin: 0 auto 1.5rem auto;
  }

  h1 {
    text-align: center;
  }

  h2 {
    font-size: 1.3rem;
    margin-top: 1.5rem;
  }

  .experience-cta {
    margin: 1rem 0 0.5rem 0;
  }

  .cta-link {
    padding: 0.5rem 1.2rem;
    font-size: 0.9rem;
  }

  .download-button {
    padding: 0.5rem 1.2rem;
    font-size: 0.85rem;
  }
}

@media (max-width: 480px) {
  h2 {
    font-size: 1.2rem;
  }

  p {
    font-size: 0.95rem;
  }
}
</style>
