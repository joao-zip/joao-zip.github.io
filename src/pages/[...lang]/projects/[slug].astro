---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../../layouts/Base.astro';
import { locales, defaultLang, type Lang } from '../../../i18n/utils';
import { getSkillIconId } from '../../../utils/techIcons';

export async function getStaticPaths() {
  const paths = [];
  for (const lang of locales) {
    const projects = await getCollection('projects', ({ id }) => id.startsWith(`${lang}/`));
    for (const project of projects) {
      paths.push({
        params: {
          lang: lang === defaultLang ? undefined : lang,
          slug: project.slug.replace(`${lang}/`, ''),
        },
        props: { project, lang },
      });
    }
  }
  return paths;
}

const { project, lang } = Astro.props;
const { Content } = await project.render();
const { title, period, img, technologies, site, github } = project.data;
---

<Base titlePage={title} lang={lang}>

  <div class="project-layout">
    <!-- Coluna Principal (Título, Logo e Conteúdo) -->
    <div class="main-column">
      <h1 class="project-title">{title}</h1>
      
      {img && (
        <div class="project-image-wrapper">
          <Image
            src={img} 
            alt="Project logo" 
            loading="lazy"
            height={150} 
            width={150}
            class="project-image"
          />
        </div>
      )}

      <div class="project-description">
        <Content />
      </div>
    </div>

    <!-- Barra Lateral (Período, Stack e Links) -->
    <aside class="sidebar">
      <div class="sidebar-section">
        <h2 class="sidebar-title">{lang === 'pt' ? 'Detalhes' : 'Details'}</h2>
        
        <div class="meta-item">
          <span class="meta-label">{lang === 'pt' ? 'Período' : 'Period'}</span>
          <span class="meta-value">{period}</span>
        </div>
      </div>

      {technologies && technologies.length > 0 && (
        <div class="sidebar-section">
          <h2 class="sidebar-title">{lang === 'pt' ? 'Tecnologias' : 'Technologies'}</h2>
          <div class="tech-tags">
            {technologies.map((tech: string) => {
              const iconId = getSkillIconId(tech);
              return (
                <span class="tech-tag">
                  {iconId && (
                    <img 
                      src={`https://skillicons.dev/icons?i=${iconId}`} 
                      alt="" 
                      class="tech-icon" 
                      width="16" 
                      height="16" 
                      loading="lazy" 
                    />
                  )}
                  <span>{tech}</span>
                </span>
              );
            })}
          </div>
        </div>
      )}

      {(site || github) && (
        <div class="sidebar-section">
          <h2 class="sidebar-title">Links</h2>
          <div class="links">
            {site && <a href={site} target="_blank">{lang === 'pt' ? 'Visitar Site' : 'Visit Site'}</a>}
            {github && <a href={github} target="_blank">{lang === 'pt' ? 'Repositório' : 'Repository'}</a>}
          </div>
        </div>
      )}
    </aside>
  </div>

</Base>

<style>
.project-layout {
  display: grid;
  grid-template-columns: 1.8fr 1fr;
  gap: 3rem;
  margin: 2rem 0 4rem 0;
  align-items: start;
}

.main-column {
  min-width: 0;
}

.project-title {
  font-family: "Crimson Text", Georgia, serif;
  font-size: 2.2rem;
  font-weight: 700;
  margin-top: 0;
  margin-bottom: 1.5rem;
  color: var(--text-color);
  line-height: 1.2;
}

.project-image-wrapper {
  margin-bottom: 2rem;
}

.project-image {
  max-width: 100%;
  height: auto;
  object-fit: contain;
}

.project-description {
  line-height: 1.7;
}

.project-description :global(ul) {
  padding-left: 1.5rem;
  margin: 1.2rem 0;
}

.project-description :global(ul li) {
  list-style-type: disc;
  margin-bottom: 0.8rem;
  text-align: justify;
}

.project-description :global(ol) {
  padding-left: 1.25rem;
  margin: 1.2rem 0;
}

.project-description :global(ol li) {
  list-style-type: decimal;
  padding-left: 0.25rem;
  margin-bottom: 0.8rem;
  text-align: justify;
}

/* Sidebar styling mimicking clean editorial design */
.sidebar {
  position: sticky;
  top: 2rem;
  display: flex;
  flex-direction: column;
  gap: 1.8rem;
  background: color-mix(in srgb, var(--text-color) 2%, transparent);
  border: 1px dashed color-mix(in srgb, var(--text-color) 15%, transparent);
  padding: 1.5rem;
  border-radius: 0;
}

.sidebar-section {
  display: flex;
  flex-direction: column;
  gap: 0.8rem;
}

.sidebar-section:not(:last-child) {
  border-bottom: 3px double color-mix(in srgb, var(--text-color) 15%, transparent);
  padding-bottom: 1.5rem;
}

.sidebar-title {
  font-family: Courier, "Courier New", Monaco, monospace;
  font-size: 0.9rem;
  font-weight: 700;
  text-transform: uppercase;
  color: var(--accent-color);
  margin: 0 0 0.2rem 0;
  letter-spacing: 0.5px;
}

.meta-item {
  display: flex;
  flex-direction: column;
  gap: 0.15rem;
}

.meta-label {
  font-family: Courier, "Courier New", Monaco, monospace;
  font-size: 0.75rem;
  opacity: 0.6;
  text-transform: uppercase;
}

.meta-value {
  font-family: "Crimson Text", Georgia, serif;
  font-size: 1.05rem;
  font-weight: 600;
}

.tech-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.tech-tag {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  padding: 0.2rem 0.5rem;
  font-family: Courier, "Courier New", Monaco, monospace;
  font-size: 0.75rem;
  font-weight: 500;
  background: color-mix(in srgb, var(--text-color) 4%, transparent);
  border: 1px solid color-mix(in srgb, var(--text-color) 8%, transparent);
  border-radius: 0;
  color: var(--text-color);
}

.tech-icon {
  width: 14px;
  height: 14px;
  object-fit: contain;
}

.links {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
}

.links a {
  display: block;
  text-align: center;
  padding: 0.5rem 1rem;
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--text-color);
  text-decoration: none;
  background: transparent;
  border: 1px solid color-mix(in srgb, var(--text-color) 15%, transparent);
  transition: all 0.2s ease;
}

.links a:hover {
  background: color-mix(in srgb, var(--text-color) 5%, transparent);
  border-color: color-mix(in srgb, var(--text-color) 25%, transparent);
  transform: translateY(-1px);
}

/* Responsiveness */
@media (max-width: 768px) {
  .project-layout {
    grid-template-columns: 1fr;
    gap: 2.5rem;
  }
  
  .sidebar {
    position: static;
    padding: 1.2rem;
  }
  
  .project-title {
    font-size: 1.8rem;
    text-align: center;
  }

  .project-image-wrapper {
    display: flex;
    justify-content: center;
    margin-bottom: 1.5rem;
  }
}
</style>
