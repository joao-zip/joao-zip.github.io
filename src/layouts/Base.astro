---
const { titlePage, lang = 'pt' } = Astro.props;

import { ViewTransitions } from 'astro:transitions';
import { useTranslations, type Lang } from '../i18n/utils';

import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const t = useTranslations(lang as Lang);
const htmlLang = lang === 'pt' ? 'pt-BR' : 'en';
---

<html lang={htmlLang}>
	<head>
	    <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <meta name="generator" content={Astro.generator} />
        <meta name="description" content={t('meta.description')} />
        <meta name="keywords" content="desenvolvedor, fullstack, C++, Python, TypeScript, ASP.NET Core, open-source, portfólio" />
        <meta name="author" content="João Pedro" />
        
        <!-- Open Graph / Facebook -->
        <meta property="og:type" content="website" />
        <meta property="og:url" content="https://joao-zip.github.io/" />
        <meta property="og:title" content={t('meta.og_title')} />
        <meta property="og:description" content={t('meta.og_description')} />
        
        <!-- Twitter -->
        <meta property="twitter:card" content="summary" />
        <meta property="twitter:url" content="https://joao-zip.github.io/" />
        <meta property="twitter:title" content={t('meta.og_title')} />
        <meta property="twitter:description" content={t('meta.og_description')} />
        
        <!-- hreflang alternates -->
        <link rel="alternate" hreflang="pt-BR" href={`https://joao-zip.github.io${Astro.url.pathname.replace(/^\/(en)(\/|$)/, '/')}`} />
        <link rel="alternate" hreflang="en" href={`https://joao-zip.github.io/en${Astro.url.pathname.replace(/^\/(en)(\/|$)/, '/')}`} />

        <script is:inline>
          (function() {
            function applyTheme() {
              const savedTheme = localStorage.getItem('theme');
              const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
              const theme = savedTheme || (prefersDark ? 'dark' : 'light');
              
              if (theme === 'dark') {
                document.documentElement.classList.add('dark');
              } else {
                document.documentElement.classList.remove('dark');
              }
            }
            
            applyTheme();
            
            document.addEventListener('astro:before-swap', applyTheme);
            document.addEventListener('astro:after-swap', applyTheme);
          })();
        </script>
        
        <ViewTransitions />
        <link rel="preconnect" href="https://fonts.googleapis.com">
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
        <link href="https://fonts.googleapis.com/css2?family=Crimson+Text:ital,wght@0,400;0,600;0,700;1,400;1,600;1,700&family=Italianno&display=swap" rel="stylesheet">
	    <link rel="icon" type="image/svg+xml" href="/svg/ink.svg" />
        <title>joao.zip | {titlePage}</title>
	</head>
    <body>
        <Header lang={lang} />
        <main transition:animate="slide">
            <slot />
        </main>
        <Footer lang={lang} />
	</body>
</html>

<style is:global>
:root {
    /* Light mode */
    --light-bg: #eee;
    --light-text: #241d19;
    --light-accent: #4C392F;
    --light-accent-hover: #3d2e26;
    
    /* Dark mode */
    --dark-bg: #1a1614;
    --dark-text: #e8e6e3;
    --dark-accent: #8b7355;
    --dark-accent-hover: #a08568;
    
    /* Active theme colors (default light) */
    --background-color: var(--light-bg);
    --text-color: var(--light-text);
    --accent-color: var(--light-accent);
    --accent-hover: var(--light-accent-hover);
    --selection-bg: var(--light-accent);
    --selection-text: var(--light-bg);
}

/* Dark mode */
:root.dark {
    --background-color: var(--dark-bg);
    --text-color: var(--dark-text);
    --accent-color: var(--dark-accent);
    --accent-hover: var(--dark-accent-hover);
    --selection-bg: var(--dark-accent);
    --selection-text: var(--dark-bg);
}

*::selection {
    background-color: var(--selection-bg);
    color: var(--selection-text);
}

body {
    margin: 0px;
    font-family: "Crimson Text", serif;
    font-size: 20px;
    background-color: var(--background-color);
    color: var(--text-color);
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    min-height: 100vh;
    align-items: center;
}

body.theme-transitioning {
    transition: background-color 0.3s ease, color 0.3s ease;
}

main {
    width: 70vw;
    max-width: 1200px;
    padding: 0 1rem;
    box-sizing: border-box;
}

p {
    text-align: justify;
}

a {
    text-decoration: none;
    color: var(--text-color);
}

li {
    list-style-type: none;
}

/* Mobile responsiveness */
@media (max-width: 768px) {
    body {
        font-size: 18px;
    }
    
    main {
        width: 92vw;
        padding: 0 0.5rem;
    }
}

@media (max-width: 480px) {
    body {
        font-size: 16px;
    }
    
    main {
        width: 95vw;
    }
}
</style>
