---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../../../layouts/Base.astro';
import { locales, defaultLang, type Lang } from '../../../i18n/utils';

export async function getStaticPaths() {
  const paths = [];
  for (const lang of locales) {
    const projects = await getCollection('projects', ({ id }) => id.startsWith(`${lang}/`));
    for (const project of projects) {
      paths.push({
        params: {
          lang: lang === defaultLang ? undefined : lang,
          slug: project.slug.replace(`${lang}/`, ''),
        },
        props: { project, lang },
      });
    }
  }
  return paths;
}

const { project, lang } = Astro.props;
const { Content } = await project.render();
const { title, period, img, site, github } = project.data;
---

<Base titlePage={title} lang={lang}>

  <div class="project-header">
    <h1>{title}</h1>
    {period && (
      <div class="project-meta">
        <span class="meta-period">{period}</span>
      </div>
    )}
  </div>

  {img && (
    <Image
      src={img} 
      alt="Project logo" 
      loading="lazy"
      height={220} 
      width={220}
      style="float: right; margin: 15px;"
    />
  )}

  <Content />

  <div class="project-links">
    {site && <a href={site} target="_blank">Site</a>}
    {github && <a href={github} target="_blank">Repo</a>}
  </div>

</Base>

<style>
.project-header {
  margin-bottom: 1.5rem;
}

.project-header h1 {
  margin-bottom: 0.5rem;
}

.project-meta {
  display: flex;
  gap: 1rem;
  flex-wrap: wrap;
  margin-bottom: 1rem;
}

.meta-period {
  font-size: 0.95rem;
  color: var(--accent-color);
  font-weight: 500;
  padding: 0.3rem 0.8rem;
  background: color-mix(in srgb, var(--accent-color) 8%, transparent);
  border: 1px solid color-mix(in srgb, var(--accent-color) 20%, transparent);
  border-radius: 6px;
}

.project-links {
  display: flex;
  gap: 1rem;
  justify-content: center;
  margin-top: 2rem;
}

.project-links a {
  padding: 0.6rem 1.5rem;
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-color);
  opacity: 0.8;
  text-decoration: none;
  background: transparent;
  border: 1px solid color-mix(in srgb, var(--text-color) 15%, transparent);
  border-radius: 6px;
  transition: all 0.2s ease;
  letter-spacing: 0.02em;
}

.project-links a:hover {
  opacity: 1;
  background: color-mix(in srgb, var(--text-color) 5%, transparent);
  border-color: color-mix(in srgb, var(--text-color) 25%, transparent);
  transform: translateY(-1px);
}

@media (max-width: 768px) {
  .project-meta {
    font-size: 0.9rem;
  }
  
  .meta-period {
    font-size: 0.85rem;
    padding: 0.25rem 0.6rem;
  }
}
</style>
