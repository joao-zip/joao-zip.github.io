---
const { frontmatter } = Astro.props;
---

<div class="project-card">
  <div class="card-header">
    <h3>{frontmatter.title}</h3>
    {frontmatter.periodo && (
      <span class="period">{frontmatter.periodo}</span>
    )}
  </div>
  {frontmatter.descricao && (
    <p class="description">{frontmatter.descricao}</p>
  )}
</div>

<style>
.project-card {
  padding: 1.2rem;
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  background: transparent;
  border: 1px solid color-mix(in srgb, var(--text-color) 10%, transparent);
  border-radius: 8px;
  transition: all 0.2s ease;
  min-height: 85px;
}

.project-card:hover {
  border-color: color-mix(in srgb, var(--text-color) 25%, transparent);
  background: color-mix(in srgb, var(--text-color) 3%, transparent);
  transform: translateY(-2px);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 1rem;
  flex-wrap: wrap;
}

.card-header h3 {
  margin: 0;
  font-size: 1rem;
  font-weight: 600;
  color: var(--text-color);
  flex: 1;
  min-width: 0; /* Allow text to shrink */
}

.period {
  font-size: 0.85rem;
  font-weight: 500;
  color: var(--accent-color);
  white-space: nowrap;
  flex-shrink: 0;
}

.description {
  margin: 0;
  font-size: 0.9rem;
  line-height: 1.4;
  color: var(--text-color);
  opacity: 0.75;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

@media (max-width: 768px) {
  .project-card {
    padding: 1rem;
    min-height: 75px;
  }
  
  .card-header {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.3rem;
  }
  
  .card-header h3 {
    font-size: 0.95rem;
  }
  
  .period {
    font-size: 0.8rem;
  }
  
  .description {
    font-size: 0.85rem;
    -webkit-line-clamp: 2;
  }
}

@media (max-width: 480px) {
  .card-header h3 {
    font-size: 0.9rem;
  }
  
  .description {
    font-size: 0.8rem;
  }
}
</style>
