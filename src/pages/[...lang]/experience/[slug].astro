---
import { getCollection } from 'astro:content';
import Base from '../../../layouts/Base.astro';
import { locales, defaultLang, type Lang } from '../../../i18n/utils';

export async function getStaticPaths() {
  const paths = [];
  for (const lang of locales) {
    const experiences = await getCollection('experience', ({ id }) => id.startsWith(`${lang}/`));
    for (const exp of experiences) {
      paths.push({
        params: {
          lang: lang === defaultLang ? undefined : lang,
          slug: exp.slug.replace(`${lang}/`, ''),
        },
        props: { experience: exp, lang },
      });
    }
  }
  return paths;
}

const { experience, lang } = Astro.props;
const { Content } = await experience.render();
const { title, period, role, company, technologies, site, github } = experience.data;
---

<Base titlePage={title} lang={lang}>

  <div class="experience-content">
    <div class="experience-header">
      <h1>{title}</h1>
      <div class="experience-meta">
        <span class="period">{period}</span>
        <span class="role">{role}</span>
        <span class="company">{company}</span>
      </div>
    </div>

    {technologies && technologies.length > 0 && (
      <div class="tech-tags">
        {technologies.map((tech: string) => (
          <span class="tech-tag">{tech}</span>
        ))}
      </div>
    )}

    <div class="experience-description">
      <Content />
    </div>

    {(site || github) && (
      <div class="links">
        {site && <a href={site} target="_blank">Site</a>}
        {github && <a href={github} target="_blank">GitHub</a>}
      </div>
    )}
  </div>

</Base>

<style>
.experience-content {
  max-width: 800px;
  margin: 0 auto;
}

.experience-header {
  margin-bottom: 2rem;
}

h1 {
  margin-bottom: 0.5rem;
  color: var(--accent-color);
}

.experience-meta {
  display: flex;
  flex-direction: column;
  gap: 0.3rem;
  font-size: 1.1rem;
  opacity: 0.85;
}

.period {
  font-weight: 600;
  color: var(--accent-color);
}

.role {
  font-style: italic;
}

.company {
  opacity: 0.7;
}

.tech-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.5rem;
  margin: 1.5rem 0;
}

.tech-tag {
  padding: 0.4rem 0.8rem;
  font-size: 0.85rem;
  background: color-mix(in srgb, var(--text-color) 5%, transparent);
  border: 1px solid color-mix(in srgb, var(--text-color) 12%, transparent);
  border-radius: 4px;
  color: var(--text-color);
  font-weight: 500;
}

.experience-description {
  margin: 2rem 0;
  line-height: 1.8;
}

.links {
  display: flex;
  gap: 1rem;
  justify-content: center;
  margin-top: 3rem;
  padding-top: 2rem;
  border-top: 1px solid color-mix(in srgb, var(--text-color) 10%, transparent);
}

.links a {
  padding: 0.6rem 1.5rem;
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-color);
  opacity: 0.8;
  text-decoration: none;
  background: transparent;
  border: 1px solid color-mix(in srgb, var(--text-color) 15%, transparent);
  border-radius: 6px;
  transition: all 0.2s ease;
  letter-spacing: 0.02em;
}

.links a:hover {
  opacity: 1;
  background: color-mix(in srgb, var(--text-color) 5%, transparent);
  border-color: color-mix(in srgb, var(--text-color) 25%, transparent);
  transform: translateY(-1px);
}

@media (max-width: 768px) {
  .tech-tags {
    gap: 0.4rem;
  }
  
  .tech-tag {
    font-size: 0.8rem;
    padding: 0.3rem 0.6rem;
  }
}
</style>
