---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { useTranslations, langParams, type Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return langParams();
}

const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
---

<Base titlePage={t('nav.home')} lang={lang}>

  <section id="hero">
    <div>
      <h1 id="typewriter"></h1>
      <span>{t('home.tagline')}</span>
    </div>

    <Image src="/svg/ink.svg" alt={t('home.ink_alt')} width={150} height={150} loading="eager" />
  </section>

  <script define:vars={{ greetingPrefix: t('home.greeting_prefix'), greetingTypo: t('home.greeting_typo'), greetingName: t('home.greeting_name') }}>
    window.__i18n = { greetingPrefix, greetingTypo, greetingName };
  </script>

  <script>
    function initTypewriter() {
      const element = document.getElementById("typewriter");
      if (!element) return;
      
      const i18n = window.__i18n || { greetingPrefix: 'Olá! Eu sou o', greetingTypo: 'jo', greetingName: ' João' };
      
      element.textContent = '';
      element.classList.remove("typing-done");
      
      const sequence = [
        { action: 'type', text: i18n.greetingPrefix, delay: 300 },
        { action: 'type', text: i18n.greetingTypo[0], delay: 150 },
        { action: 'type', text: i18n.greetingTypo[1], delay: 200 },
        { action: 'delete', count: 2, delay: 300 },
        { action: 'pause', delay: 400 },
        { action: 'type', text: i18n.greetingName, delay: 100 }
      ];

      let currentText = '';
      let sequenceIndex = 0;
      let charIndex = 0;

      function executeSequence() {
        if (sequenceIndex >= sequence.length) {
          element.classList.add("typing-done");
          return;
        }

        const current = sequence[sequenceIndex];
        
        if (current.action === 'type') {
          if (charIndex < current.text.length) {
            currentText += current.text[charIndex];
            element.textContent = currentText;
            charIndex++;
            
            const randomDelay = current.delay + Math.random() * 50;
            setTimeout(executeSequence, randomDelay);
          } else {
            charIndex = 0;
            sequenceIndex++;
            setTimeout(executeSequence, current.delay);
          }
        } else if (current.action === 'delete') {
          if (charIndex < current.count) {
            currentText = currentText.slice(0, -1);
            element.textContent = currentText;
            charIndex++;
            setTimeout(executeSequence, 80);
          } else {
            charIndex = 0;
            sequenceIndex++;
            setTimeout(executeSequence, current.delay);
          }
        } else if (current.action === 'pause') {
          sequenceIndex++;
          setTimeout(executeSequence, current.delay);
        }
      }

      executeSequence();
    }

    initTypewriter();
    document.addEventListener('astro:page-load', initTypewriter);
  </script>
</Base>

<style>

#hero {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

div {
    text-align: justify;
}

h1 {
  margin: 0;
  font-size: 4rem;
  min-height: 5rem;
}

h1:not(.typing-done)::after {
  content: '|';
  animation: blink 0.7s infinite;
}

@keyframes blink {
  0%, 50% {
    opacity: 1;
  }
  51%, 100% {
    opacity: 0;
  }
}

span {
  font-family: "Italianno", cursive;
  font-size: 3rem;
}

.zip {
  font-family: "Inter", serif;
  font-size: 2rem;
}
</style>
