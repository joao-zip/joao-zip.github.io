---
import { Image } from 'astro:assets';
import Base from '../../layouts/Base.astro';
import { useTranslations, getLocalizedPath, getCvPath, langParams, type Lang } from '../../i18n/utils';

export function getStaticPaths() {
  return langParams();
}

const { lang } = Astro.props as { lang: Lang };
const t = useTranslations(lang);
---

<Base titlePage={t('about.title')} lang={lang}>

  <link href="https://assets.calendly.com/assets/external/widget.css" rel="stylesheet" media="print" onload="this.media='all'">
  <script src="https://assets.calendly.com/assets/external/widget.js" type="text/javascript" async defer></script>
  
  <h1>{t('about.title')}</h1>

  <Image
  src="/me.jpg" alt="João Pedro" 
  loading="eager"
  height={200} width={200}
  style="float: right; border-radius: 10px; margin-left: 15px;"
  />

  <p set:html={t('about.intro')} />

  <h2>{t('about.current_experience_title')}</h2>
  <p set:html={t('about.current_experience_text')} />

  <div class="experience-cta">
    <a href={getLocalizedPath('/experience', lang)} class="cta-link">{t('about.see_full_experience')}</a>
  </div>

  <h2>{t('about.outside_code_title')}</h2>
  <p>{t('about.outside_code_text')}</p>

  <h2>{t('about.lets_talk_title')}</h2>
  <p>{t('about.lets_talk_text')}</p>
  
  <div style="margin-top: 2rem; text-align: center; display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
    <a class="download-button" href={getCvPath(lang)} download>{t('about.download_cv')}</a>
    <a class="download-button secondary" href="" onclick="Calendly.initPopupWidget({url: 'https://calendly.com/oliveira-joao-unifesp/30min'});return false;">{t('about.schedule_call')}</a>
  </div>

</Base>

<style>
a {
  text-decoration: underline;
}

p {
  text-align: justify;
}

h2 {
  margin-top: 2rem;
  margin-bottom: 0.5rem;
  font-size: 1.5rem;
  color: var(--accent-color);
}

.experience-cta {
  margin: 1.5rem 0 0.5rem 0;
  text-align: center;
}

.cta-link {
  display: inline-block;
  padding: 0.6rem 1.5rem;
  font-size: 0.95rem;
  font-weight: 500;
  color: var(--accent-color);
  text-decoration: none;
  background: color-mix(in srgb, var(--accent-color) 8%, transparent);
  border: 1px solid color-mix(in srgb, var(--accent-color) 20%, transparent);
  border-radius: 6px;
  transition: all 0.2s ease;
  letter-spacing: 0.02em;
}

.cta-link:hover {
  background: color-mix(in srgb, var(--accent-color) 15%, transparent);
  border-color: var(--accent-color);
  transform: translateY(-1px);
}

.download-button {
  padding: 0.6rem 1.5rem;
  font-size: 0.9rem;
  font-weight: 500;
  color: var(--text-color);
  opacity: 0.8;
  text-decoration: none;
  background: transparent;
  border: 1px solid color-mix(in srgb, var(--text-color) 15%, transparent);
  border-radius: 6px;
  transition: all 0.2s ease;
  letter-spacing: 0.02em;
  display: inline-block;
}

.download-button:hover {
  opacity: 1;
  background: color-mix(in srgb, var(--text-color) 5%, transparent);
  border-color: color-mix(in srgb, var(--text-color) 25%, transparent);
  transform: translateY(-1px);
}

.download-button.secondary {
  background: var(--accent-color);
  color: var(--background-color);
  border-color: var(--accent-color);
  opacity: 1;
}

.download-button.secondary:hover {
  background: var(--accent-hover);
  border-color: var(--accent-hover);
  color: var(--background-color);
}

@media (max-width: 768px) {
  .skills-section {
    grid-template-columns: 1fr;
    gap: 1rem;
  }
}
</style>
