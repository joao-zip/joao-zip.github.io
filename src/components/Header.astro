---
import ThemeToggle from './ThemeToggle.astro';
import LanguageSwitcher from './LanguageSwitcher.astro';
import { useTranslations, getLocalizedPath, type Lang } from '../i18n/utils';

const { lang = 'pt' } = Astro.props;
const t = useTranslations(lang as Lang);

const currentLang = lang as Lang;
---

<header>
  <nav>
    <a href={getLocalizedPath('/', currentLang)}>{t('nav.home')}</a>
    <a href={getLocalizedPath('/aboutme', currentLang)}>{t('nav.about')}</a>
    <a href={getLocalizedPath('/projects', currentLang)}>{t('nav.projects')}</a>
    <a href={getLocalizedPath('/experience', currentLang)}>{t('nav.experience')}</a>
    <div class="nav-controls">
      <LanguageSwitcher lang={currentLang} currentUrl={Astro.url} />
      <ThemeToggle />
    </div>
  </nav>
</header>

<style>
header {
  min-width: 70vw;
}

nav {
  padding: 0;
  margin-top: 10px;
  display: flex;
  justify-content: space-evenly;
  align-items: center;
  color: grey;
}

nav a {
  padding: 0 .5em .25em;
  cursor: pointer;
  position: relative;
  overflow: hidden;
  transition: .3s;
  font-size: 1.3rem;
  font-weight: 500;
}

nav a:hover {
  color: var(--dark-brown);
}

nav a:not(.lang-switcher):before {
  content: "";
  position: absolute;
  inset: calc(100% - 1px) 0 0 0;
  background: var(--light-brown);
  scale: 0 1;
  transition: .3s, translate 0s .3s;
}

nav:hover a:not(.lang-switcher):before {
  scale: 1;
}

nav a:not(.lang-switcher):hover:before {
  translate: 0;
  transition: .3s;
}

nav:hover a:not(.lang-switcher):has(~ a:not(.lang-switcher):hover):before {
  translate: 100% 0;
  transition: .2s .2s,scale 0s .4s;
}

nav:hover a:not(.lang-switcher):hover ~ a:not(.lang-switcher):before {
  translate: -100% 0;
  transition: .2s .2s,scale 0s .4s;
}

.nav-controls {
  display: flex;
  align-items: center;
  gap: 0.8rem;
}
</style>
